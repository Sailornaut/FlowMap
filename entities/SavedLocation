{
  "name": "SavedLocation",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the location or address"
    },
    "address": {
      "type": "string",
      "description": "Full address"
    },
    "latitude": {
      "type": "number",
      "description": "Latitude coordinate"
    },
    "longitude": {
      "type": "number",
      "description": "Longitude coordinate"
    },
    "traffic_score": {
      "type": "number",
      "description": "Overall foot traffic score 0-100"
    },
    "peak_hours": {
      "type": "array",
      "description": "Peak traffic hours",
      "items": {
        "type": "object",
        "properties": {
          "hour": {
            "type": "string"
          },
          "traffic": {
            "type": "number"
          }
        }
      }
    },
    "daily_pattern": {
      "type": "array",
      "description": "Daily traffic pattern Mon-Sun",
      "items": {
        "type": "object",
        "properties": {
          "day": {
            "type": "string"
          },
          "traffic": {
            "type": "number"
          }
        }
      }
    },
    "nearby_pois": {
      "type": "array",
      "description": "Nearby points of interest",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "distance": {
            "type": "string"
          }
        }
      }
    },
    "demographics": {
      "type": "object",
      "description": "Demographic breakdown",
      "properties": {
        "commuters": {
          "type": "number"
        },
        "residents": {
          "type": "number"
        },
        "tourists": {
          "type": "number"
        },
        "shoppers": {
          "type": "number"
        }
      }
    },
    "estimated_daily_foot_traffic": {
      "type": "number",
      "description": "Estimated daily foot traffic count"
    },
    "business_suitability": {
      "type": "string",
      "enum": [
        "excellent",
        "good",
        "moderate",
        "low"
      ],
      "description": "Business suitability rating"
    },
    "notes": {
      "type": "string",
      "description": "User notes about this location"
    }
  },
  "required": [
    "name",
    "latitude",
    "longitude"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}